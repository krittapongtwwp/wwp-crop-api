// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/database/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum LoginMethod {
  local
  azure
  sso
  oa
}

// Audit Log
enum AuditAction {
  login
  logout
  view
  create
  edit
  delete
  export
}

// Transaction Log – เก็บ old_value / new_value
enum TransactionAction {
  create
  edit
  delete
}

enum Status {
  enabled
  disabled
  deleted

  @@map("HeroBannerStatus")
}

enum RoleStatus {
  enabled
  disabled
  deleted
}

enum Gender {
  male
  female
}

/// Per-user access to a DMCR agency id (see AgencyContext item.id)
enum UserAgencyAccessLevel {
  read_only
  manage
  no_access
}

enum MediaType {
  thumbnail // รูปภาพสำหรับ thumbnail
  gallery // รูปภาพหลายๆรูป
  attachment // ไฟล์แนบ
  editor // รูปภาพสำหรับ editor
  other // อื่นๆ
  vdo // ไฟล์วิดีโอ mp4
}

enum MouVideoType {
  youtube
  upload
}

model sys_role {
  id                Int                   @id @default(autoincrement())
  uuid              String                @unique @default(uuid()) @db.VarChar(36)
  name              String                @db.VarChar(50)
  description       String?               @db.Text
  data_access_level Int                   @default(2) // 0: NONE, 1: MASKED, 2: PARTIAL, 3: FULL
  is_active         Boolean               @default(true) // 0: inactive, 1: active
  is_deleted        Boolean               @default(false) // 0: not deleted, 1: deleted
  created_by        String?               @db.VarChar(36)
  created_by_name   String?               @db.VarChar(100)
  created_date      DateTime              @default(now())
  updated_by        String?               @db.VarChar(36)
  updated_by_name   String?               @db.VarChar(100)
  updated_date      DateTime              @updatedAt
  permissions       sys_role_permission[]
  assignments       sys_role_assignment[]

  @@map("sys_role")
}

model sys_role_permission {
  id              Int      @id @default(autoincrement())
  uuid            String   @unique @default(uuid()) @db.VarChar(36)
  role_id         Int      @db.Integer
  menu_identifier String   @db.VarChar(100)
  can_view        Boolean  @default(false)
  can_create      Boolean  @default(false)
  can_update      Boolean  @default(false)
  can_delete      Boolean  @default(false)
  created_by      String?  @db.VarChar(36)
  created_by_name String?  @db.VarChar(100)
  created_date    DateTime @default(now())
  updated_by      String?  @db.VarChar(36)
  updated_by_name String?  @db.VarChar(100)
  updated_date    DateTime @updatedAt
  role            sys_role @relation(fields: [role_id], references: [id], onDelete: Cascade, map: "sys_role_permission_role_fkey")

  @@unique([role_id, menu_identifier])
  @@index([menu_identifier], map: "sys_role_permission_menu_identifier_idx")
  @@map("sys_role_permission")
}

model sys_user {
  id               Int                   @id @default(autoincrement())
  uuid             String                @unique @default(uuid()) @db.VarChar(36)
  email            String                @unique @db.VarChar(100)
  username         String                @unique @db.VarChar(50)
  password_hash    String?               @db.VarChar(255) // password hash
  gender           Gender                @default(male)
  first_name       String?               @db.VarChar(50)
  last_name        String?               @db.VarChar(50)
  phone_number     String?               @db.VarChar(20) // phone number
  avatar           String?               @db.VarChar(255) // avatar image
  last_login_date  DateTime?
  login_method     LoginMethod           @default(local)
  is_active        Boolean               @default(true) // 0: inactive, 1: active
  is_deleted       Boolean               @default(false) // 0: not deleted, 1: deleted
  user_type        Int                   @default(2) // 0: super admin, 1: admin, 2: user
  created_by       String?               @db.VarChar(36)
  created_by_name  String?               @db.VarChar(100)
  created_date     DateTime              @default(now())
  updated_by       String?               @db.VarChar(36)
  updated_by_name  String?               @db.VarChar(100)
  updated_date     DateTime              @updatedAt
  main_agency      Int?                  @db.Integer // หน่วยงานหลัก
  sub_agency       Int?                  @db.Integer // หน่วยงานย่อย
  note             String?               @db.Text
  address          String?               @db.Text
  position         String?               @db.VarChar(255) // position of career
  mobile           String?               @db.VarChar(20) // mobile phone number
  refresh_token    sys_refresh_token[]
  assignments      sys_role_assignment[]
  agency_access_assignments sys_user_agency_assignment[]
  audit_logs       sys_audit_log[]
  transaction_logs sys_transaction_log[]

  @@map("sys_user")
}

model sys_user_agency_assignment {
  user_id      Int                   @db.Integer
  agency_id    Int                   @db.Integer
  access_level UserAgencyAccessLevel @default(no_access)
  created_by   String?               @db.VarChar(36)
  created_date DateTime              @default(now())

  user sys_user @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "sys_user_agency_assignment_user_fkey")

  @@id([user_id, agency_id])
  @@index([agency_id], map: "sys_user_agency_assignment_agency_id_idx")
  @@map("sys_user_agency_assignment")
}

model sys_role_assignment {
  role_id      Int      @db.Integer
  user_id      Int      @db.Integer
  created_by   String?  @db.VarChar(36)
  created_date DateTime @default(now())

  role sys_role @relation(fields: [role_id], references: [id], onDelete: Cascade, map: "sys_role_assignment_role_fkey")
  user sys_user @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "sys_role_assignment_user_fkey")

  // composite id (many-to-many relationship)
  @@id([role_id, user_id])
  @@map("sys_role_assignment")
}

model sys_refresh_token {
  id              Int      @id @default(autoincrement())
  uuid            String   @unique @default(uuid()) @db.VarChar(36)
  user_id         Int      @db.Integer
  token           String   @db.Text // refresh token
  expires_at      DateTime // refresh token expires at
  is_active       Boolean  @default(true) // 0: inactive, 1: active
  device_name     String?  @db.VarChar(255)
  device_ip       String?  @db.VarChar(255)
  created_by      String?  @db.VarChar(36)
  created_by_name String?  @db.VarChar(100)
  created_date    DateTime @default(now())
  updated_by      String?  @db.VarChar(36)
  updated_by_name String?  @db.VarChar(100)
  updated_date    DateTime @updatedAt
  user            sys_user @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "sys_refresh_token_user_fkey")

  @@index([user_id], map: "sys_refresh_token_user_idx")
  @@map("sys_refresh_token")
}

model sys_setting {
  id                       Int      @id @default(autoincrement())
  uuid                     String   @unique @default(uuid()) @db.VarChar(36)
  title                    String   @db.VarChar(200) 
  description              String?  @db.Text 
  file_retention_days      Int      @default(30) 
  log_file_retention_count Int      @default(10) 
  audit_retention_days     Int      @default(90) 
  timezone                 String   @default("Asia/Bangkok") @db.VarChar(50)
  date_format              String   @default("DD/MM/YYYY") @db.VarChar(50)
  time_format              String   @default("HH:mm:ss") @db.VarChar(50)
  default_language         String   @default("th") @db.VarChar(10)
  maintenance_mode         Boolean  @default(false) 
  meta                     Json? 
  is_active                Boolean  @default(true)
  created_by               String?  @db.VarChar(36)
  created_by_name          String?  @db.VarChar(100)
  created_date             DateTime @default(now())
  updated_by               String?  @db.VarChar(36)
  updated_by_name          String?  @db.VarChar(100)
  updated_date             DateTime @updatedAt

  @@map("sys_setting")
}

model sys_language {
  id              Int      @id @default(autoincrement())
  uuid            String   @unique @default(uuid()) @db.VarChar(36)
  code            String   @unique @db.VarChar(10)
  name            String   @db.VarChar(100)
  native_name     String   @db.VarChar(100)
  flag_icon       String?  @db.VarChar(50)
  is_default      Boolean  @default(false) // 0: not default, 1: default
  is_active       Boolean  @default(true) // 0: inactive, 1: active
  is_deleted      Boolean  @default(false) // 0: not deleted, 1: deleted
  sequence        Int?     @default(1)
  sort_order      Int      @default(0)
  created_by      String?  @db.VarChar(36)
  created_by_name String?  @db.VarChar(100)
  created_date    DateTime @default(now())
  updated_by      String?  @db.VarChar(36)
  updated_by_name String?  @db.VarChar(100)
  updated_date    DateTime @updatedAt

  sys_translations         sys_translation[]             @relation("LangSysTranslations")
  hero_banner_translations mod_hero_banner_translation[]
  mod_banner_translations  mod_banner_translation[]
  master_translations      mod_master_translation[]
  mou_list_translations    mod_mou_list_translation[]

  @@index([code], map: "idx_sys_language_code")
  @@index([name], map: "idx_sys_language_name")
  @@index([is_default], map: "idx_sys_language_is_default")
  @@index([is_active], map: "idx_sys_language_is_active")
  @@index([is_deleted], map: "idx_sys_language_is_deleted")
  @@index([sequence], map: "idx_language_sequence")
}

model sys_translation_variable {
  id              Int               @id @default(autoincrement())
  uuid            String            @unique @default(uuid()) @db.VarChar(36)
  namespace       String            @db.VarChar(50)
  key             String            @db.VarChar(255)
  default_value   String?           @db.Text
  description     String?           @db.Text
  sequence        Int?              @default(1)
  is_active       Boolean           @default(true)
  is_deleted      Boolean           @default(false)
  created_by      String?           @db.VarChar(36)
  created_by_name String?           @db.VarChar(100)
  created_date    DateTime          @default(now())
  updated_by      String?           @db.VarChar(36)
  updated_by_name String?           @db.VarChar(100)
  updated_date    DateTime          @updatedAt
  translations    sys_translation[]

  @@unique([namespace, key])
  @@index([namespace], map: "sys_translation_variable_namespace_idx")
  @@index([sequence], map: "sys_translation_variable_sequence_idx")
  @@map("sys_translation_variable")
}

model sys_translation {
  id                      Int                       @id @default(autoincrement())
  uuid                    String                    @unique @default(uuid()) @db.VarChar(36)
  translation_variable_id Int?                      @db.Integer
  language_id             Int                       @db.Integer
  namespace               String                    @db.VarChar(50)
  key                     String                    @db.VarChar(255)
  value                   String                    @db.Text
  is_active               Boolean                   @default(true)
  is_deleted              Boolean                   @default(false)
  created_by              String?                   @db.VarChar(36)
  created_by_name         String?                   @db.VarChar(100)
  created_date            DateTime                  @default(now())
  updated_by              String?                   @db.VarChar(36)
  updated_by_name         String?                   @db.VarChar(100)
  updated_date            DateTime                  @updatedAt
  language                sys_language              @relation("LangSysTranslations", fields: [language_id], references: [id], onDelete: Cascade, map: "sys_translation_language_fkey")
  translation_variable    sys_translation_variable? @relation(fields: [translation_variable_id], references: [id], onDelete: SetNull, map: "sys_translation_variable_fkey")

  @@unique([language_id, namespace, key])
  @@index([language_id], map: "sys_translation_language_idx")
  @@index([namespace], map: "sys_translation_namespace_idx")
  @@index([translation_variable_id], map: "sys_translation_variable_id_idx")
  @@map("sys_translation")
}

model mod_master {
  id              Int                      @id @default(autoincrement())
  uuid            String                   @unique @default(uuid()) @db.VarChar(36)
  status          Status                   @default(enabled)
  color_code      String?                  @db.VarChar(20)
  cover_image     String?                  @db.VarChar(36)
  created_by      String?                  @db.VarChar(36)
  created_by_name String?                  @db.VarChar(100)
  created_date    DateTime                 @default(now())
  updated_by      String?                  @db.VarChar(36)
  updated_by_name String?                  @db.VarChar(100)
  updated_date    DateTime                 @updatedAt
  menu_identifier String?                  @db.VarChar(100)
  translations    mod_master_translation[]
  mou_lists_as_resource_type mod_mou_list[] @relation("MouListResourceType")

  @@index([status], map: "master_status_idx")
  @@index([menu_identifier], map: "master_menu_identifier_idx")
  @@map("mod_master")
}

model mod_master_translation {
  id              Int         @id @default(autoincrement())
  uuid            String      @unique @default(uuid()) @db.VarChar(36)
  content_id      Int         @db.Integer
  language_code   String      @db.VarChar(10)
  title           String      @db.VarChar(200)
  description     String?     @db.Text
  created_by      String?     @db.VarChar(36)
  created_by_name String?     @db.VarChar(100)
  created_date    DateTime    @default(now())
  updated_by      String?     @db.VarChar(36)
  updated_by_name String?     @db.VarChar(100)
  updated_date    DateTime    @updatedAt
  content         mod_master  @relation(fields: [content_id], references: [id], onDelete: Cascade, map: "master_translation_content_fkey")
  language        sys_language @relation(fields: [language_code], references: [code], onDelete: Cascade, map: "master_translation_language_fkey")

  @@unique([content_id, language_code])
  @@index([language_code], map: "master_translation_language_idx")
  @@map("mod_master_translation")
}

model sys_audit_log {
  id            Int         @id @default(autoincrement())
  uuid          String      @unique @default(uuid()) @db.VarChar(36)
  user_id       Int?        @db.Integer // null if anonymous/system
  username      String?     @db.VarChar(100) // snapshot in case user deleted
  action        AuditAction
  entity        String      @db.VarChar(100) // User, Role, Menu, Setting, etc.
  entity_id     String?     @db.VarChar(36) // uuid of record
  description   String?     @db.VarChar(500) // short description
  ip_address    String?     @db.VarChar(45)
  user_agent    String?     @db.VarChar(500)
  device_name   String?     @db.VarChar(255)
  device_id     String?     @db.VarChar(100)
  is_success    Boolean     @default(true)
  error_message String?     @db.Text
  created_at    DateTime    @default(now())
  user          sys_user?   @relation(fields: [user_id], references: [id], onDelete: SetNull, map: "sys_audit_log_user_fkey")

  @@index([user_id], map: "sys_audit_log_user_idx")
  @@index([entity, entity_id], map: "sys_audit_log_entity_idx")
  @@index([action], map: "sys_audit_log_action_idx")
  @@index([created_at], map: "sys_audit_log_created_at_idx")
  @@map("sys_audit_log")
}

model sys_transaction_log {
  id             Int               @id @default(autoincrement())
  uuid           String            @unique @default(uuid()) @db.VarChar(36)
  entity         String            @db.VarChar(100) // User, Role, Setting, Menu, etc.
  entity_id      String            @db.VarChar(36)
  ref_uuid       String?           @db.VarChar(36)
  action         TransactionAction
  old_value      Json? // ข้อมูลเดิม (ก่อนแก้) – กรองฟิลด์ละเอียดอ่อนแล้ว
  new_value      Json? // ข้อมูลใหม่ (หลังแก้)w
  changed_fields Json? // รายชื่อฟิลด์ที่เปลี่ยน (สำหรับ update)
  user_id        Int?              @db.Integer
  username       String?           @db.VarChar(100)
  ip_address     String?           @db.VarChar(45)
  user_agent     String?           @db.VarChar(500)
  device_name    String?           @db.VarChar(255)
  device_id      String?           @db.VarChar(100)
  created_at     DateTime          @default(now())
  user           sys_user?         @relation(fields: [user_id], references: [id], onDelete: SetNull, map: "sys_transaction_log_user_fkey")

  @@index([entity], map: "sys_transaction_log_entity_idx")
  @@index([entity_id], map: "sys_transaction_log_entity_id_idx")
  @@index([action], map: "sys_transaction_log_action_idx")
  @@index([user_id], map: "sys_transaction_log_user_idx")
  @@index([created_at], map: "sys_transaction_log_created_at_idx")
  @@map("sys_transaction_log")
}

model mod_hero_banner {
  id                  Int                           @id @default(autoincrement())
  uuid                String                        @unique @default(uuid()) @db.VarChar(36)
  menu_identifier     String?                       @db.VarChar(20)
  desktop_image       String?                       @db.VarChar(500)
  mobile_image        String?                       @db.VarChar(500)
  button_url          String?                       @db.VarChar(500)
  sequence            Int                           @default(0)
  transition_duration Int                           @default(5000)
  display_start_date  DateTime?
  display_end_date    DateTime?
  status              Status                        @default(enabled)
  is_open_new_tab     Boolean                       @default(false)
  is_active           Boolean                       @default(true)
  sort_order          Int                           @default(0)
  view_count          Int                           @default(0)
  created_by          String?                       @db.VarChar(36)
  created_by_name     String?                       @db.VarChar(100)
  created_date        DateTime                      @default(now())
  updated_by          String?                       @db.VarChar(36)
  updated_by_name     String?                       @db.VarChar(100)
  updated_date        DateTime                      @updatedAt
  translations        mod_hero_banner_translation[]

  @@index([status], map: "mod_hero_banner_status_idx")
  @@index([sequence], map: "mod_hero_banner_sequence_idx")
  @@map("mod_hero_banner")
}

model mod_hero_banner_translation {
  id              Int             @id @default(autoincrement())
  uuid            String          @unique @default(uuid()) @db.VarChar(36)
  banner_id       Int             @db.Integer
  language_code   String          @db.VarChar(10)
  name            String          @db.VarChar(200)
  description     String?         @db.Text
  button_name     String?         @db.VarChar(100)
  is_active       Boolean         @default(true)
  created_by      String?         @db.VarChar(36)
  created_by_name String?         @db.VarChar(100)
  created_date    DateTime        @default(now())
  updated_by      String?         @db.VarChar(36)
  updated_by_name String?         @db.VarChar(100)
  updated_date    DateTime        @updatedAt
  banner          mod_hero_banner @relation(fields: [banner_id], references: [id], onDelete: Cascade, map: "mod_hero_banner_translation_banner_fkey")
  language        sys_language    @relation(fields: [language_code], references: [code], onDelete: Cascade, map: "mod_hero_banner_translation_language_fkey")

  @@unique([banner_id, language_code])
  @@index([language_code], map: "mod_hero_banner_translation_language_idx")
  @@map("mod_hero_banner_translation")
}

model mod_banner {
  id                  Int                      @id @default(autoincrement())
  uuid                String                   @unique @default(uuid()) @db.VarChar(36)
  menu_identifier     String?                  @db.VarChar(20)
  desktop_image       String?                  @db.VarChar(500)
  mobile_image        String?                  @db.VarChar(500)
  button_url          String?                  @db.VarChar(500)
  sequence            Int                      @default(0)
  transition_duration Int                      @default(5000)
  display_start_date  DateTime?
  display_end_date    DateTime?
  status              Status                   @default(enabled)
  is_open_new_tab     Boolean                  @default(false)
  is_active           Boolean                  @default(true)
  sort_order          Int                      @default(0)
  view_count          Int                      @default(0)
  created_by          String?                  @db.VarChar(36)
  created_by_name     String?                  @db.VarChar(100)
  created_date        DateTime                 @default(now())
  updated_by          String?                  @db.VarChar(36)
  updated_by_name     String?                  @db.VarChar(100)
  updated_date        DateTime                 @updatedAt
  translations        mod_banner_translation[]

  @@index([status], map: "mod_banner_status_idx")
  @@index([sequence], map: "mod_banner_sequence_idx")
  @@map("mod_banner")
}

model mod_banner_translation {
  id              Int          @id @default(autoincrement())
  uuid            String       @unique @default(uuid()) @db.VarChar(36)
  banner_id       Int          @db.Integer
  language_code   String       @db.VarChar(10)
  name            String       @db.VarChar(200)
  description     String?      @db.Text
  button_name     String?      @db.VarChar(100)
  is_active       Boolean      @default(true)
  created_by      String?      @db.VarChar(36)
  created_by_name String?      @db.VarChar(100)
  created_date    DateTime     @default(now())
  updated_by      String?      @db.VarChar(36)
  updated_by_name String?      @db.VarChar(100)
  updated_date    DateTime     @updatedAt
  banner          mod_banner   @relation(fields: [banner_id], references: [id], onDelete: Cascade, map: "mod_banner_translation_banner_fkey")
  language        sys_language @relation(fields: [language_code], references: [code], onDelete: Cascade, map: "mod_banner_translation_language_fkey")

  @@unique([banner_id, language_code])
  @@index([language_code], map: "mod_banner_translation_language_idx")
  @@map("mod_banner_translation")
}

model sys_media {
  id              Int       @id @default(autoincrement()) // id of media
  uuid            String    @unique @default(uuid()) @db.VarChar(36) // uuid of media
  type            MediaType @default(other) // type of media
  ref_uuid        String?   @db.VarChar(36) // uuid of record
  menu_identifier String?   @db.VarChar(20) // menu identifier
  name            String    @db.VarChar(200) // name of media
  original_name   String    @db.VarChar(200) // original name of media
  mime_type       String    @db.VarChar(100) // mime type of media
  path_file       String    @db.VarChar(500) // path of media
  size            Int       @default(0) // size of media
  view_count      Int       @default(0) // view count of media
  download_count  Int       @default(0) // download count of media
  sequence        Int       @default(0) // sequence of media
  created_by      String?   @db.VarChar(36) // created by
  created_by_name String?   @db.VarChar(100) // created by name
  created_date    DateTime  @default(now()) // created date
  updated_by      String?   @db.VarChar(36) // updated by
  updated_by_name String?   @db.VarChar(100) // updated by name
  updated_date    DateTime  @updatedAt // updated date

  @@index([sequence], map: "sys_media_sequence_idx")
  @@index([ref_uuid], map: "sys_media_ref_uuid_idx")
  @@index([menu_identifier], map: "sys_media_menu_identifier_idx")
  @@index([ref_uuid, menu_identifier, type], map: "sys_media_scope_idx")
  @@map("sys_media")
}

model mod_mou_list {
  id                 Int                      @id @default(autoincrement())
  uuid               String                   @unique @default(uuid()) @db.VarChar(36)
  agency_id          Int?                     @db.Integer
  resource_type_id   Int?                     @db.Integer
  sequence           Int                      @default(0)
  sort_order         Int                      @default(0)
  view_count         Int                      @default(0)
  publish_date       DateTime?
  cover_image        String?                  @db.VarChar(36) // media uuid of cover image
  video_type         MouVideoType?
  video_url          String?                  @db.VarChar(500)
  video_file         String?                  @db.VarChar(36) // media uuid of uploaded mp4
  attachment_file    String?                  @db.VarChar(36) // media uuid of attachment file
  tag_title          String?                  @db.VarChar(255)
  tag_description    String?                  @db.Text
  tag_keywords       String?                  @db.Text
  status             Status                   @default(enabled)
  pin_status         Boolean                  @default(false)
  display_start_date DateTime?
  display_end_date   DateTime?
  duration_start_mou DateTime?
  duration_end_mou   DateTime?
  created_by         String?                  @db.VarChar(36)
  created_by_name    String?                  @db.VarChar(100)
  created_date       DateTime                 @default(now())
  updated_by         String?                  @db.VarChar(36)
  updated_by_name    String?                  @db.VarChar(100)
  updated_date       DateTime                 @updatedAt
  resource_type      mod_master?              @relation("MouListResourceType", fields: [resource_type_id], references: [id], onDelete: Restrict, map: "sys_mou_list_resource_type_fkey")
  galleries          mod_mou_list_gallery[]
  translations       mod_mou_list_translation[]

  @@index([agency_id], map: "sys_mou_list_agency_idx")
  @@index([resource_type_id], map: "sys_mou_list_resource_type_idx")
  @@index([publish_date], map: "sys_mou_list_publish_date_idx")
  @@index([status], map: "sys_mou_list_status_idx")
  @@index([sequence], map: "mod_mou_list_sequence_idx")
  @@index([display_start_date], map: "sys_mou_list_display_start_date_idx")
  @@index([display_end_date], map: "sys_mou_list_display_end_date_idx")
  @@map("mod_mou_list")
}

model mod_mou_list_gallery {
  id              Int          @id @default(autoincrement())
  uuid            String       @unique @default(uuid()) @db.VarChar(36)
  content_id      Int          @db.Integer
  media_uuid      String       @db.VarChar(36)
  sequence        Int          @default(0)
  created_by      String?      @db.VarChar(36)
  created_by_name String?      @db.VarChar(100)
  created_date    DateTime     @default(now())
  updated_by      String?      @db.VarChar(36)
  updated_by_name String?      @db.VarChar(100)
  updated_date    DateTime     @updatedAt
  content         mod_mou_list @relation(fields: [content_id], references: [id], onDelete: Cascade, map: "sys_mou_list_gallery_content_fkey")

  @@index([content_id], map: "sys_mou_list_gallery_content_idx")
  @@index([media_uuid], map: "sys_mou_list_gallery_media_uuid_idx")
  @@index([sequence], map: "sys_mou_list_gallery_sequence_idx")
  @@unique([content_id, media_uuid], map: "sys_mou_list_gallery_content_media_uuid_key")
  @@map("mod_mou_list_gallery")
}

model mod_mou_list_translation {
  id              Int          @id @default(autoincrement())
  uuid            String       @unique @default(uuid()) @db.VarChar(36)
  content_id      Int          @db.Integer
  language_code   String       @db.VarChar(10)
  title             String       @db.VarChar(200)
  topic_description String?      @db.Text
  description       String?      @db.Text
  created_by      String?      @db.VarChar(36)
  created_by_name String?      @db.VarChar(100)
  created_date    DateTime     @default(now())
  updated_by      String?      @db.VarChar(36)
  updated_by_name String?      @db.VarChar(100)
  updated_date    DateTime     @updatedAt
  content         mod_mou_list @relation(fields: [content_id], references: [id], onDelete: Cascade, map: "sys_mou_list_translation_content_fkey")
  language        sys_language @relation(fields: [language_code], references: [code], onDelete: Cascade, map: "sys_mou_list_translation_language_fkey")

  @@unique([content_id, language_code])
  @@index([language_code], map: "sys_mou_list_translation_language_idx")
  @@map("mod_mou_list_translation")
}
