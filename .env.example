# ─────────────────────────────────────────────
# Database (PostgreSQL)
# ─────────────────────────────────────────────
# For Render / external Postgres, MUST include ?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME?sslmode=require"

# Used by raw pg connection / scripts (optional, mirrors DATABASE_URL parts)
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=wwp_cms

# ─────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────
# Render injects PORT automatically — leave unset on Render
PORT=3000
NODE_ENV=development

# ─────────────────────────────────────────────
# Auth
# ─────────────────────────────────────────────
# Use a long random string in production (e.g. `openssl rand -hex 32`)
JWT_SECRET=change-me-to-a-long-random-string

# ─────────────────────────────────────────────
# CORS
# ─────────────────────────────────────────────
# Frontend origin allowed in production
FRONTEND_URL=https://your-frontend-domain.com
